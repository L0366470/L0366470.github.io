/* Chapter-6 JavaJam Lorraine Cortez*/

/* { box-sizing for all elements */ 
* {
	box-sizing: border-box;
}

/* Styles for the body */
body {
    margin: 0;
	background-color: #D2B48C;
	color: #221811;
	font-family: Tahoma, Arial, sans-serif;
}

/* Styles for the wrapper */
#wrapper {
    background-color: #231814;
    padding: 0;
}
/* Styles for header */
header {
    padding-top: 5px;
    padding-bottom: 5px;
    color: #231814;
	background-color: #D2B48C;
	background-image: url(images/cup.jpg);
	background-repeat: no-repeat;
	padding-left: 105px;
	height: 128px;
}

header a {
	text-decoration: none;
}
header a:link {
	color: #231814;
}
header a:visited {
	color: #231814;
}
header a:hover {
	color: #FEF6C2;
}
/* Stlyes for the headers */
h1 {font-size: 2em;}
h2 { color: #8C3826; }
h3, dt { color: #8C3826; }

h4 {
    background-color: #D2B48C;
    font-size: 1.2em;
    padding-left: .5em;
    padding-bottom: 0;
	text-transform: uppercase;
    border-bottom: 1px solid #221811;
    clear: left;
}
/*Set navigation bar style */
nav {
    font-size: 1.5em;
	text-align: center;
}
nav a {
    text-decoration: none;
}
/*Pseudo class for nav links */
nav a:link {
	color: #FEF6C2; 
}

nav a:visited {
	color: #D2B48C; 
}
	
nav a:hover {
	color: #CC9933;
}

nav ul {
	display: flex;
	list-style-type: none;
	flex-direction: column;
	margin: 0;
	padding: 0;
	font-size: 1.25em;
}
/* nav li selector */
nav li {
	padding: .5em 1em;
	width: 100%;
	border-bottom: 1px solid #FEF6C2;
}
main {
	background-color: #FEF6C2;
	display: block;
	padding: 0 0 2em 0;
}
h2,h3,h4,p,div,ul,dl {
	padding-left: 1em;
	padding-right: 1em;
}
main ul {
	padding-left: 2em;
}
/* Styles for details */
.details {
    padding-left: 20%;
	padding-right: 20%;
	overflow: auto;
}
/* styles for images */
img {
	padding-left: 10px;
	padding-right: 10px;
}
/* styles for home hero */
#homehero {
    background-image: url(images/road.jpg);
    height: 300px;
    background-size: 100% 100%;
	background-repeat: no-repeat;
}
#heromugs {
    background-image: url(images/threemugs.jpg);
    height: 300px;
    background-size: 100% 100%;
    background-repeat: no-repeat;
}
#heroguitar {
    background-image: url(images/guitar.jpg);
    height: 300px;
    background-size: 100% 100%;
    background-repeat: no-repeat;
}
/* styles for mobile */
#mobile {
    display: inline;
}
/* styles for desktop */
#desktop {
    display: none;
}
/* Styles for the Footer */
footer {
	padding-bottom: 1em;
	border-top: 2px solid #8C3826;
	background-color: #D2B48C;
	font-size: 0.60em;
	font-style: italic;
	text-align: center;
}
/* -- Table Styling for JavaJam -- */
table {
    width: 90%;
    margin: 0 auto;      /
    border-spacing: 0;   
}
th, td {
    padding: 10px;       
}
/* Alternate row background color */
tr:nth-of-type(odd) {
    background-color: #D2B48E;
}
/* media query for desktop */
@media (min-width: 600px) {
	header {
	padding-left: 0;
	text-align: center;
}
 h1 {
    font-size: 3em;
}
nav ul {
	flex-flow: row nowrap;
    justify-content: space-around;
    }
 nav li {
     border-bottom: none;
 }
#homehero {
	height: 50vh;
	background-image: url(images/hero.jpg);
}
#heromugs {
	background-image: url(images/heromugs.jpg);
}

#heroguitar {
    background-image: url(images/heroguitar.jpg);
}
#flow {
	display:flex;
	flex-direction: row;
}
#mobile {
    display: none;
}
#desktop {
     display: inline;
}
.details {
     display: flex;
     flex-direction: row;
}
h4 {
     margin-left: 10%;
     margin-right: 10%;
}
form {
	width:40%;
	display: grid;
	grid-gap: 1em;
	gap: 1em;
	grid-template-columns: 6em 1fr;
}
input[type="submit"] {
	grid-column: 2/3;
	width: 9em;
}
#herojobs {
	background-image: url(herojobs.jpg);
	}
}
table {
	margin: auto;
	width: 90%;
	border-spacing: 0;
}
th,td {
	padding: 10px;
}
tr:nth-of-type(odd) {
	background-color:#D2B48E;
}
/* form styles */
form {
	display: flex;
	flex-direction: column;
	padding-left: 1em;
	width: 80%;
}
input,textarea {
	margin-bottom: .5em;
}
/* media query large screens */
@media (min-width: 1024px) {
    @supports (display: grid) {
        header {
            grid-area: header;
        }
		nav {
            grid-area: nav;
        }
        main {
            grid-area: main;
        }
        footer {
            grid-area: footer;
        }
        #wrapper {
            display: grid;
            grid-template:
                "header header"
                "nav main"
                "footer footer"
                / 200px;
        }
        nav ul {
            flex-direction: column;
        }
        header {
            background-image: url(images/coffeelogo.jpg);
        }
    }
}

